{
  "name": "@microsoft/fast-element",
  "description": "A library for constructing Web Components",
  "version": "3.0.0-rc.3",
  "author": {
    "name": "Microsoft",
    "url": "https://discord.gg/FcSNfg4"
  },
  "homepage": "https://www.fast.design/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Microsoft/fast.git",
    "directory": "packages/fast-element"
  },
  "bugs": {
    "url": "https://github.com/Microsoft/fast/issues/new/choose"
  },
  "type": "module",
  "main": "dist/esm/index.js",
  "types": "dist/dts/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/dts/index.d.ts",
      "production": "./dist/esm/index.js",
      "development": "./dist/esm/index.debug.js",
      "default": "./dist/esm/index.js"
    },
    "./arrays.js": {
      "types": "./dist/dts/observation/arrays.d.ts",
      "default": "./dist/esm/observation/arrays.js"
    },
    "./attr.js": {
      "types": "./dist/dts/components/attributes.d.ts",
      "default": "./dist/esm/components/attributes.js"
    },
    "./attribute-map.js": {
      "types": "./dist/dts/declarative/attribute-map.d.ts",
      "default": "./dist/esm/declarative/attribute-map.js"
    },
    "./binding.js": {
      "types": "./dist/dts/binding/exports.d.ts",
      "default": "./dist/esm/binding/exports.js"
    },
    "./children.js": {
      "types": "./dist/dts/templating/children.d.ts",
      "default": "./dist/esm/templating/children.js"
    },
    "./context.js": {
      "types": "./dist/dts/context.d.ts",
      "default": "./dist/esm/context.js"
    },
    "./css.js": {
      "types": "./dist/dts/styles/css.d.ts",
      "default": "./dist/esm/styles/css.js"
    },
    "./debug.js": {
      "types": "./dist/dts/debug.d.ts",
      "default": "./dist/esm/debug.js"
    },
    "./declarative-utilities.js": {
      "types": "./dist/dts/declarative/utilities.d.ts",
      "default": "./dist/esm/declarative/utilities.js"
    },
    "./declarative.js": {
      "types": "./dist/dts/declarative/index.d.ts",
      "default": "./dist/esm/declarative/index.js"
    },
    "./di.js": {
      "types": "./dist/dts/di/di.d.ts",
      "default": "./dist/esm/di/di.js"
    },
    "./dom-policy.js": {
      "types": "./dist/dts/dom-policy.d.ts",
      "default": "./dist/esm/dom-policy.js"
    },
    "./dom.js": {
      "types": "./dist/dts/dom.d.ts",
      "default": "./dist/esm/dom.js"
    },
    "./fast-element.js": {
      "types": "./dist/dts/components/fast-element.d.ts",
      "default": "./dist/esm/components/fast-element.js"
    },
    "./html.js": {
      "types": "./dist/dts/templating/html.d.ts",
      "default": "./dist/esm/templating/html.js"
    },
    "./hydration.js": {
      "types": "./dist/dts/hydration/exports.d.ts",
      "default": "./dist/esm/hydration/exports.js"
    },
    "./notifier.js": {
      "types": "./dist/dts/observation/notifier.d.ts",
      "default": "./dist/esm/observation/notifier.js"
    },
    "./observable.js": {
      "types": "./dist/dts/observation/observable.d.ts",
      "default": "./dist/esm/observation/observable.js"
    },
    "./observer-map.js": {
      "types": "./dist/dts/declarative/observer-map.d.ts",
      "default": "./dist/esm/declarative/observer-map.js"
    },
    "./ref.js": {
      "types": "./dist/dts/templating/ref.d.ts",
      "default": "./dist/esm/templating/ref.js"
    },
    "./registry.js": {
      "types": "./dist/dts/registry.d.ts",
      "default": "./dist/esm/registry.js"
    },
    "./render.js": {
      "types": "./dist/dts/render.d.ts",
      "default": "./dist/esm/render.js"
    },
    "./repeat.js": {
      "types": "./dist/dts/templating/repeat.d.ts",
      "default": "./dist/esm/templating/repeat.js"
    },
    "./schema.js": {
      "types": "./dist/dts/schema.d.ts",
      "default": "./dist/esm/schema.js"
    },
    "./signal.js": {
      "types": "./dist/dts/binding/signal.d.ts",
      "default": "./dist/esm/binding/signal.js"
    },
    "./slotted.js": {
      "types": "./dist/dts/templating/slotted.d.ts",
      "default": "./dist/esm/templating/slotted.js"
    },
    "./state.js": {
      "types": "./dist/dts/state/exports.d.ts",
      "default": "./dist/esm/state/exports.js"
    },
    "./two-way.js": {
      "types": "./dist/dts/binding/two-way.d.ts",
      "default": "./dist/esm/binding/two-way.js"
    },
    "./updates.js": {
      "types": "./dist/dts/observation/update-queue.d.ts",
      "default": "./dist/esm/observation/update-queue.js"
    },
    "./utilities.js": {
      "types": "./dist/dts/utilities.d.ts",
      "default": "./dist/esm/utilities.js"
    },
    "./volatile.js": {
      "types": "./dist/dts/observation/volatile.d.ts",
      "default": "./dist/esm/observation/volatile.js"
    },
    "./when.js": {
      "types": "./dist/dts/templating/when.d.ts",
      "default": "./dist/esm/templating/when.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/fast-element.min.js",
  "sideEffects": false,
  "scripts": {
    "clean": "clean dist temp test-results",
    "doc": "api-extractor run --local",
    "doc:ci": "api-extractor run",
    "doc:exports": "node ./scripts/run-api-extractor.js",
    "doc:path-exports": "node ./scripts/check-path-exports-docs.js --write",
    "doc:path-exports:check": "node ./scripts/check-path-exports-docs.js --check",
    "doc:exports:ci": "node ./scripts/run-api-extractor.js ci",
    "build": "npm run build:tsc && npm run test:exports && npm run build:rollup && npm run build:sizes && npm run doc && npm run doc:exports && npm run build:fixtures",
    "build:fixtures": "node scripts/declarative/build-fixtures.js",
    "build:fixtures:webui": "node scripts/declarative/build-fixtures-with-webui.js",
    "build:rollup": "rollup -c",
    "build:sizes": "node scripts/measure-sizes.js",
    "build:tsc": "tsgo -p ./tsconfig.json",
    "dev": "tsgo -p ./tsconfig.json -w",
    "dev:declarative": "concurrently -k -n tsc,server \"npm run dev\" \"npm run test-server:declarative\"",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "biome-changed",
    "lint:fix": "biome-changed -- --fix",
    "test:playwright": "playwright test && npm run test:playwright:declarative",
    "test:exports": "node ./scripts/smoke-package-exports.js",
    "test:playwright:declarative": "playwright test --config=playwright.declarative.config.ts",
    "test:chromium": "playwright test --project=chromium && npm run test:chromium:declarative",
    "test:chromium:declarative": "playwright test --config=playwright.declarative.config.ts --project=chromium",
    "test-server": "npx vite test/ --clearScreen false",
    "test-server:declarative": "npx vite test/declarative --clearScreen false --port 5174 --strictPort",
    "test-server:declarative:webui": "npx vite temp/integrations/webui --clearScreen false --port 5174 --strictPort",
    "test": "npm run lint && npm run doc:path-exports:check && npm run doc:ci && npm run doc:exports:ci && npm run test:exports && npm run test:playwright",
    "test:ci": "npm run doc:path-exports:check && npm run doc:ci && npm run doc:exports:ci && npm run test:exports && npm run test:playwright",
    "test:ui:declarative": "concurrently -k -n tsc,playwright \"npm run dev\" \"npx playwright test --config=playwright.declarative.config.ts --ui\"",
    "test:webui-integration": "npm run build:fixtures:webui && playwright test --config=playwright.declarative.webui.config.ts"
  },
  "devDependencies": {
    "@microsoft/fast-build": "0.8.1-fast-element-v3-rc-20260615",
    "@microsoft/webui": "0.0.12"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
