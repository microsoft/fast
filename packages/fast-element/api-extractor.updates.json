{
    "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
    "extends": "../../api-extractor.json",
    "mainEntryPointFilePath": "./dist/dts/updates.d.ts",
    "dtsRollup": {
        "enabled": false
    },
    "apiReport": {
        "enabled": true,
        "reportFolder": "<projectFolder>/docs/updates",
        "reportFileName": "api-report"
    },
    "docModel": {
        "enabled": true,
        "apiJsonFilePath": "<projectFolder>/dist/updates/updates.api.json"
    }
}
