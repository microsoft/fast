{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": "./src",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "skipLibCheck": true,
        "strict": false,
        "declarationDir": "dist/dts",
        "sourceMap": false,
        "outDir": "dist/esm"
    },
    "include": ["src/**/*.ts"]
}
