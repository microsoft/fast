{
  "name": "@microsoft/fast-build",
  "version": "0.9.0",
  "description": "CLI and Node.js API for server-side rendering and converting FAST declarative HTML templates.",
  "author": {
    "name": "Microsoft",
    "url": "https://discord.gg/FcSNfg4"
  },
  "homepage": "https://www.fast.design/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Microsoft/fast.git",
    "directory": "packages/fast-build"
  },
  "bugs": {
    "url": "https://github.com/microsoft/fast/issues/new/choose"
  },
  "exports": {
    "./bin/fast.js": "./bin/fast.js",
    "./wasm/microsoft_fast_build.js": "./wasm/microsoft_fast_build.js",
    "./wasm/convert/microsoft_fast_convert.js": "./wasm/convert/microsoft_fast_convert.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "fast": "./bin/fast.js"
  },
  "files": [
    "bin",
    "get-package-json.js",
    "wasm/microsoft_fast_build.js",
    "wasm/microsoft_fast_build_bg.wasm",
    "wasm/microsoft_fast_build.d.ts",
    "wasm/microsoft_fast_build_bg.wasm.d.ts",
    "wasm/convert/microsoft_fast_convert.js",
    "wasm/convert/microsoft_fast_convert_bg.wasm",
    "wasm/convert/microsoft_fast_convert.d.ts",
    "wasm/convert/microsoft_fast_convert_bg.wasm.d.ts"
  ],
  "scripts": {
    "build": "node build-wasm.cjs",
    "test:node": "node --test test/config.test.js test/fixtures/convert/convert-fixtures.test.js",
    "test:fixtures:convert": "node --test test/fixtures/convert/convert-fixtures.test.js"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "beachball": {
    "disallowedChangeTypes": [
      "prerelease",
      "major"
    ]
  }
}
