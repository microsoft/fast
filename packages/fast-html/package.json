{
  "name": "@microsoft/fast-html",
  "version": "1.0.0-alpha.50",
  "type": "module",
  "author": {
    "name": "Microsoft",
    "url": "https://discord.gg/FcSNfg4"
  },
  "homepage": "https://www.fast.design/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Microsoft/fast.git",
    "directory": "packages/fast-html"
  },
  "bugs": {
    "url": "https://github.com/Microsoft/fast/issues/new/choose"
  },
  "files": [
    "dist",
    "rules/*.yml"
  ],
  "scripts": {
    "build:tsc": "tsgo -p ./tsconfig.json",
    "build": "npm run build:tsc && npm run doc && npm run build:fixtures",
    "build:fixtures": "node scripts/build-fixtures.js",
    "build:fixtures:webui": "node scripts/build-fixtures-with-webui.js",
    "clean": "clean dist temp test-results",
    "dev:full": "concurrently -k -n fast-element,fast-html,server \"npm run dev --workspace=@microsoft/fast-element\" \"npm:watch\" \"npm:test-server\"",
    "dev": "concurrently -k -n tsgo,server \"npm run watch\" \"npm run test-server\"",
    "doc:ci": "api-extractor run",
    "doc": "npm run doc:ci -- --local",
    "lint": "biome-changed",
    "lint:fix": "biome-changed -- --fix",
    "install-playwright-browsers": "npm run playwright install",
    "prepublishOnly": "npm run clean && npm run build",
    "test-server": "npx vite test/ --clearScreen false --port 5174",
    "test:playwright": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:rules": "sg test --skip-snapshot-tests",
    "test-server:webui": "vite temp/integrations/webui --clearScreen false --port 5174 --strictPort",
    "test:webui-integration": "npm run build:fixtures:webui && npm exec -- playwright test --config=playwright.webui.config.ts",
    "test": "npm run test:playwright",
    "test:ui": "concurrently -k -n fast-element,fast-html,playwright \"npm run dev --workspace=@microsoft/fast-element\" \"npm:watch\" \"npx playwright test --ui\"",
    "watch": "npm run build:tsc -- -w --preserveWatchOutput"
  },
  "description": "A package for facilitating rendering FAST Web Components in a non-browser environment.",
  "exports": {
    ".": {
      "types": "./dist/dts/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./utilities.js": {
      "types": "./dist/dts/components/utilities.d.ts",
      "default": "./dist/esm/components/utilities.js"
    },
    "./syntax.js": {
      "types": "./dist/dts/components/syntax.d.ts",
      "default": "./dist/esm/components/syntax.js"
    },
    "./rules/*.yml": "./rules/*.yml",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/esm/index.js"
  ],
  "peerDependencies": {
    "@microsoft/fast-element": "^2.10.4"
  },
  "devDependencies": {
    "@microsoft/fast-build": "^0.4.0",
    "@microsoft/fast-element": "^2.10.4",
    "@microsoft/webui": "0.0.10"
  },
  "beachball": {
    "disallowedChangeTypes": [
      "major",
      "minor",
      "patch"
    ]
  }
}
