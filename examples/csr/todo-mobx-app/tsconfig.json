{
    "compilerOptions": {
        "pretty": true,
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "importHelpers": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmitOnError": true,
        "strict": true,
        "outDir": "dist",
        "rootDir": "src",
        "lib": ["dom", "esnext"]
    },
    "include": ["src"]
}
